object frmTacticalHUD: TfrmTacticalHUD
  Left = 320
  Height = 490
  Top = 150
  Width = 720
  BorderIcons = [biSystemMenu, biMinimize]
  BorderStyle = bsDialog
  Caption = 'TACTICAL HUD & FLIGHT COMMAND'
  ClientHeight = 490
  ClientWidth = 720
  Color = clBlack
  Font.Color = 3799828
  Font.Height = -12
  Font.Name = 'Consolas'
  LCLVersion = '4.4.0.0'
  OnClose = FormClose
  OnCreate = FormCreate
  OnShow = FormShow
  object pnHUD: TPanel
    Left = 10
    Height = 220
    Top = 10
    Width = 390
    BevelOuter = bvNone
    ClientHeight = 220
    ClientWidth = 390
    Color = 2039583
    ParentBackground = False
    ParentColor = False
    TabOrder = 0
    object Label1: TLabel
      Left = 15
      Height = 19
      Top = 10
      Width = 198
      Caption = 'DRONE TELEMETRY DATA'
