      Font.Height = -16
      Font.Name = 'Consolas'
      Font.Style = [fsBold]
      ParentColor = False
    end
    object Label2: TLabel
      Left = 15
      Height = 15
      Top = 45
      Width = 72
      Caption = 'LATITUDE: '
      ParentColor = False
    end
    object lblLat: TLabel
      Left = 110
      Height = 15
      Top = 45
      Width = 56
      Caption = '0.000000'
      ParentColor = False
    end
    object Label3: TLabel
      Left = 15
      Height = 15
      Top = 75
      Width = 80
      Caption = 'LONGITUDE: '
      ParentColor = False
    end
    object lblLon: TLabel
      Left = 110
      Height = 15
      Top = 75
      Width = 56
      Caption = '0.000000'
      ParentColor = False
    end
    object Label4: TLabel
      Left = 15
      Height = 15
      Top = 105
      Width = 72
      Caption = 'ALTITUDE: '
      ParentColor = False
    end
    object lblAlt: TLabel
      Left = 110
      Height = 15
      Top = 105
      Width = 28
      Caption = '0.0 m'
      ParentColor = False
    end
    object Label5: TLabel
      Left = 15
      Height = 15
      Top = 135
      Width = 80
      Caption = 'GND SPEED: '
      ParentColor = False
    end
    object lblSpeed: TLabel
      Left = 110
      Height = 15
      Top = 135
      Width = 42
      Caption = '0.0 m/s'
      ParentColor = False
    end
    object lblStatus: TLabel
      Left = 15
      Height = 15
      Top = 175
      Width = 350
      Caption = 'STATUS: STANDBY'
      Font.Color = 3799828
      Font.Style = [fsBold]
      ParentColor = False
    end
  end
  object pnControls: TPanel
    Left = 10
    Height = 190
    Top = 240
    Width = 390
    BevelOuter = bvNone
    ClientHeight = 190
    ClientWidth = 390
    Color = 2039583
    ParentBackground = False
    ParentColor = False
    TabOrder = 1
    object Label6: TLabel
      Left = 15
      Height = 19
      Top = 10
      Width = 207
      Caption = 'SAFETY BOUNDS CONTROLS'
      Font.Color = 3799828
      Font.Height = -16
      Font.Name = 'Consolas'
      Font.Style = [fsBold]
      ParentColor = False
    end
    object ckGeofenceActive: TCheckBox
      Left = 15
      Height = 19
      Top = 45
      Width = 175
      Caption = 'ACTIVATE GEOFENCE'
      TabOrder = 0
      OnChange = ckGeofenceActiveChange
    end
    object ckAltitudeActive: TCheckBox
      Left = 15
      Height = 19
      Top = 75
      Width = 210
      Caption = 'ACTIVATE ALTITUDE ALARM'
      TabOrder = 1
      OnChange = ckAltitudeActiveChange
    end
    object Label7: TLabel
      Left = 15
      Height = 15
      Top = 115
      Width = 144
      Caption = 'MAX/MIN ALTITUDE (m):'
