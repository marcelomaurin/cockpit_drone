    AutoSize = False
    Caption = 'SYSTEM ACTIVE'
    Color = clBlack
    Font.Color = 3799828
    Font.Height = -12
    Font.Style = [fsBold]
    Layout = tlCenter
    ParentColor = False
    Transparent = False
  end
  object tmHUDUpdate: TTimer
    Enabled = False
    Interval = 100
    OnTimer = tmHUDUpdateTimer
    Left = 350
    Top = 180
  end
