      Width = 162
      Caption = 'MISSION WAYPOINTS'
      Font.Color = 3799828
      Font.Height = -16
      Font.Name = 'Consolas'
      Font.Style = [fsBold]
      ParentColor = False
    end
  end
  object btnStartRoute: TButton
    Left = 10
    Height = 40
    Top = 440
    Width = 160
